# ─────────────────────────────────────────────────────────────
# CREDENCIALES MTProto — obtenerlas en https://my.telegram.org
#   1. Iniciá sesión con tu número de teléfono
#   2. Ir a "API development tools"
#   3. Crear una app (nombre y plataforma pueden ser cualquier cosa)
#   4. Copiar el "App api_id" y el "App api_hash" aquí
# ─────────────────────────────────────────────────────────────
API_ID=
API_HASH=

# ─────────────────────────────────────────────────────────────
# GRUPO FUENTE — el grupo donde está el usuario a escuchar
#   Puede ser:
#   - Username del grupo público:  cryptotradingpro
#   - ID numérico del grupo:       -1001234567890
#   Para descubrir el ID correcto: npm run list
# ─────────────────────────────────────────────────────────────
SOURCE_GROUP=

# USERNAME del usuario cuyos mensajes querés reenviar (sin @)
SOURCE_USER=

# ─────────────────────────────────────────────────────────────
# DESTINO — a dónde llegan los mensajes reenviados
#   Puede ser:
#   - Username de un bot o canal:  @mibot
#   - ID numérico de un chat
#   - "me" para tu propio chat (Mensajes guardados)
# ─────────────────────────────────────────────────────────────
DEST_CHAT=

# ─────────────────────────────────────────────────────────────
# SESIÓN — se genera automáticamente en el primer inicio
#   No completar manualmente; el script lo llena solo
# ─────────────────────────────────────────────────────────────
SESSION=
